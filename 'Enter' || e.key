' ') {
              onSelect(entry);
            }
          }}
        >
          <div className="history-expression">{entry.expression}</div>
          <div className="history-result">= {entry.result}</div>
        </div>
      ))}
    </div>
  );
};

export default CalculationHistory;
</file>

<file path="src/components/ShareButton.tsx">
'use client';

import React, { useState } from 'react';

interface ShareButtonProps {
  expression: string;
  result: string;
  onShared: () => void;
}

const ShareButton: React.FC<ShareButtonProps> = ({ expression, result, onShared }) => {
  const [sharing, setSharing] = useState(false);
  const [shared, setShared] = useState(false);

  const canShare = expression.trim() !== '' && result.trim() !== '' && result !== 'Error';

  const handleShare = async () => {
    if (!canShare || sharing) return;

    setSharing(true);
    try {
      // First save the calculation
      const saveRes = await fetch('/api/calculations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ expression, result }),
      });
      const saveData = await saveRes.json();

      if (saveData.success && saveData.data?.id) {
        // Then mark it as shared
        await fetch(`/api/calculations/${saveData.data.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ shared: true }),
        });
      }

      setShared(true);
      onShared();
      setTimeout(() => setShared(false), 2000);
    } catch (error) {
      console.error('Share error:', error);
    } finally {
      setSharing(false);
    }
  };

  return (
    <button
      className="share-button"
      onClick={handleShare}
      disabled={!canShare || sharing}
    >
      {sharing ? '⏳ Sharing...' : shared ? '✓ Shared!' : '📤 Share to Feed'}
    </button>
  );
};

export default ShareButton;
</file>

<file path="src/components/Calculator.tsx">
'use client';

import React, { useState, useCallback, useEffect } from 'react';
import Display from '@/components/Display';
import CalculatorButton from '@/components/CalculatorButton';
import CalculationHistory from '@/components/CalculationHistory';
import ShareButton from '@/components/ShareButton';
import { evaluate } from '@/lib/calculator';
import { CalcButton } from '@/types';

interface CalculatorProps {
  onShare: () => void;
}

const BUTTONS: CalcButton[] = [
  { label: 'C', value: 'clear', type: 'action' },
  { label: '(', value: '(', type: 'action' },
  { label: ')', value: ')', type: 'action' },
  { label: '÷', value: '÷', type: 'operator' },

  { label: '7', value: '7', type: 'number' },
  { label: '8', value: '8', type: 'number' },
  { label: '9', value: '9', type: 'number' },
  { label: '×', value: '×', type: 'operator' },

  { label: '4', value: '4', type: 'number' },
  { label: '5', value: '5', type: 'number' },
  { label: '6', value: '6', type: 'number' },
  { label: '−', value: '−', type: 'operator' },

  { label: '1', value: '1', type: 'number' },
  { label: '2', value: '2', type: 'number' },
  { label: '3', value: '3', type: 'number' },
  { label: '+', value: '+', type: 'operator' },

  { label: '0', value: '0', type: 'number', span: 2 },
  { label: '.', value: '.', type: 'number' },
  { label: '=', value: '=', type: 'equals' },
];

interface HistoryEntry {
  expression: string;
  result: string;
}

const Calculator: React.FC<CalculatorProps> = ({ onShare }) => {
  const [expression, setExpression] = useState('');
  const [display, setDisplay] = useState('0');
  const [isResult, setIsResult] = useState(false);
  const [isError, setIsError] = useState(false);
  const [history, setHistory] = useState<HistoryEntry[]>([]);
  const [lastExpression, setLastExpression] = useState('');
  const [lastResult, setLastResult] = useState('');

  const handleClear = useCallback(() => {
    setExpression('');
    setDisplay('0');
    setIsResult(false);
    setIsError(false);
  }, []);

  const handleEvaluate = useCallback(() => {
    if (!expression) return;

    try {
      const result = evaluate(expression);
      setLastExpression(expression);
      setLastResult(result);
      setDisplay(result);
      setIsResult(true);
      setIsError(false);
      setHistory(prev => [{ expression, result }, ...prev].slice(0, 20));

      // Save to API
      fetch('/api/calculations', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ expression, result }),
      }).catch(console.error);
    } catch {
      setDisplay('Error');
      setIsResult(true);
      setIsError(true);
    }
  }, [expression]);

  const handleInput = useCallback((value: string) => {
    if (value === 'clear') {
      handleClear();
      return;
    }

    if (value === '=') {
      handleEvaluate();
      return;
    }

    setIsError(false);

    if (isResult) {
      // After showing a result
      const operators = ['+', '−', '×', '÷'];
      if (operators.includes(value)) {
        // Continue with the result
        setExpression(display + value);
        setIsResult(false);
      } else {
        // Start fresh
        setExpression(value);
        setDisplay(value);
        setIsResult(false);
      }
      return;
    }

    const newExpression = expression + value;
    setExpression(newExpression);
    setDisplay(newExpression);
  }, [expression, display, isResult, handleClear, handleEvaluate]);

  // Keyboard support
  useEffect(() => {
    const handleKeyDown = (e: KeyboardEvent) => {
      const key = e.key;

      if (key >= '0' && key <= '9') {
        handleInput(key);
      } else if (key === '.') {
        handleInput('.');
      } else if (key === '+') {
        handleInput('+');
      } else if (key === '-') {
        handleInput('−');
      } else if (key === '*') {
        handleInput('×');
      } else if (key === '/') {
        e.preventDefault();
        handleInput('÷');
      } else if (key