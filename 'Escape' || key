'Delete') {
        handleClear();
      } else if (key === 'Backspace') {
        if (isResult) {
          handleClear();
        } else {
          const newExpr = expression.slice(0, -1);
          setExpression(newExpr);
          setDisplay(newExpr || '0');
        }
      }
    };

    window.addEventListener('keydown', handleKeyDown);
    return () => window.removeEventListener('keydown', handleKeyDown);
  }, [handleInput, handleEvaluate, handleClear, expression, isResult]);

  const handleHistorySelect = useCallback((entry: HistoryEntry) => {
    setExpression(entry.expression);
    setDisplay(entry.result);
    setIsResult(true);
    setIsError(false);
    setLastExpression(entry.expression);
    setLastResult(entry.result);
  }, []);

  return (
    <>
      <div className="calculator-wrapper">
        <div className="calculator-header">
          <span className="calculator-title">Calculator</span>
          <span className="keyboard-hint">⌨ Keyboard enabled</span>
        </div>

        <Display
          expression={isResult ? expression : ''}
          result={display}
          error={isError}
        />

        <div className="button-grid">
          {BUTTONS.map((btn) => (
            <CalculatorButton
              key={btn.label + btn.value}
              label={btn.label}
              type={btn.type}
              span={btn.span}
              onClick={() => handleInput(btn.value)}
            />
          ))}
        </div>

        <ShareButton
          expression={lastExpression}
          result={lastResult}
          onShared={onShare}
        />
      </div>

      <CalculationHistory
        history={history}
        onSelect={handleHistorySelect}
      />
    </>
  );
};

export default Calculator;
