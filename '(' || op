')') {
      throw new Error('Mismatched parentheses');
    }
    outputQueue.push(op);
  }

  // Evaluate RPN
  const evalStack: number[] = [];
  for (const item of outputQueue) {
    if (typeof item === 'number') {
      evalStack.push(item);
    } else {
      if (evalStack.length < 2) {
        throw new Error('Invalid expression');
      }
      const b = evalStack.pop()!;
      const a = evalStack.pop()!;
      evalStack.push(applyOperator(a, b, item));
    }
  }

  if (evalStack.length !== 1) {
    throw new Error('Invalid expression');
  }

  const result = evalStack[0];

  // Round to avoid floating point issues
  return Math.round(result * 1e12) / 1e12;
}

/**
 * Formats a number result for display.
 */
export function formatResult(value: number): string {
  if (!isFinite(value)) {
    return 'Error';
  }

  // If the number is very large or very small, use scientific notation
  if (Math.abs(value) >= 1e15 || (Math.abs(value) < 1e-10 && value !== 0)) {
    return value.toExponential(6);
  }

  // Format with up to 10 decimal places, removing trailing zeros
  const formatted = value.toFixed(10).replace(/\.?0+$/, '');
  return formatted;
}

/**
 * Validates whether a partial expression is valid for continued input.
 */
export function isValidPartialExpression(expression: string): boolean {
  if (!expression) return true;

  // Check for consecutive operators (except unary minus)
  if (/[+*/]{2,}/.test(expression)) return false;
  if (/[+\-*/]$/.test(expression) && expression.length === 0) return false;

  // Check balanced parentheses (open >= close)
  let parenCount = 0;
  for (const char of expression) {
    if (char === '(') parenCount++;
    if (char === ')') parenCount--;
    if (parenCount < 0) return false;
  }

  return true;
}
