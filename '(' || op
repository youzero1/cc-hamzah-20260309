'use client';

import React, { useState } from 'react';

interface ShareButtonProps {
  expression: string;
  result: string;
}

export default function ShareButton({ expression, result }: ShareButtonProps) {
  const [shared, setShared] = useState(false);

  const handleShare = async () => {
    if (!expression || !result) return;

    const text = `🧮 ${expression} = ${result}\n\nCalculated with cc calculator`;

    if (navigator.share) {
      try {
        await navigator.share({
          title: 'cc Calculator',
          text,
        });
      } catch {
        // User cancelled or share failed - fall back to clipboard
        await copyToClipboard(text);
      }
    } else {
      await copyToClipboard(text);
    }
  };

  const copyToClipboard = async (text: string) => {
    try {
      await navigator.clipboard.writeText(text);
      setShared(true);
      setTimeout(() => setShared(false), 2000);
    } catch {
      // Clipboard API not available
      console.warn('Clipboard API not available');
    }
  };

  const isDisabled = !expression || !result || result === 'Error';

  return (
    <button
      onClick={handleShare}
      disabled={isDisabled}
      className={`flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium transition-all duration-200 ${
        isDisabled
          ? 'bg-white/5 text-white/20 cursor-not-allowed'
          : shared
          ? 'bg-green-500/20 text-green-300 border border-green-500/20'
          : 'bg-white/5 hover:bg-white/10 text-white/60 hover:text-white/80 border border-white/10'
      }`}
      aria-label="Share calculation"
    >
      {shared ? (
        <>
          <svg
            className="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              strokeLinecap="round"
